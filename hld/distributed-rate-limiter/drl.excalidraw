      "seed": 1063890686,
      "version": 12,
      "versionNonce": 1790604386,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776617571714,
      "link": null,
      "locked": false,
      "text": " On Reject send \n http status - 429 with headers\n\n X-RateLimit-Limit: The rate limit ceiling for that request (e.g., \"100\")\n X-RateLimit-Remaining: Number of requests left in the current window (e.g., \"0\")\n X-RateLimit-Reset: When the rate limit resets, as a Unix timestamp (e.g., \"1640995200\")",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "VgOXOuWm5icVtaj3wcQDJ",
      "originalText": " On Reject send \n http status - 429 with headers\n\n X-RateLimit-Limit: The rate limit ceiling for that request (e.g., \"100\")\n X-RateLimit-Remaining: Number of requests left in the current window (e.g., \"0\")\n X-RateLimit-Reset: When the rate limit resets, as a Unix timestamp (e.g., \"1640995200\")",
      "autoResize": true,
      "lineHeight": 1.35
    },
