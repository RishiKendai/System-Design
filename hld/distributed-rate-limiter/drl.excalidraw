    {
      "id": "avT5hrTnbnpeP9hOScetH",
      "type": "text",
      "x": 1099.888269044748,
      "y": 750.9758078474628,
      "width": 809.2390747070312,
      "height": 162,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
