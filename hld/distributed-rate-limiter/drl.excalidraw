  "elements": [
    {
      "id": "IdpNliSAOSbu4BaeIZ00C",
      "type": "text",
      "x": 312.5546875,
      "y": 214.25,
      "width": 626.4992065429688,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
