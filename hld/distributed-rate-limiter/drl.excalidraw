      "groupIds": [],
      "frameId": null,
      "index": "a0",
      "roundness": null,
      "seed": 1730123042,
      "version": 484,
      "versionNonce": 1712097890,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776600635303,
      "link": null,
      "locked": false,
      "text": "Functional Requirements\n- Identify the client by user_id/ip address/api_key\n- Should limit the request based on configurable rules\n- On exceeding the limit the system should reject request by http 429\n  and include  helpful headers (ratelimit-remaining, reset time, etc) ",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements\n- Identify the client by user_id/ip address/api_key\n- Should limit the request based on configurable rules\n- On exceeding the limit the system should reject request by http 429\n  and include  helpful headers (ratelimit-remaining, reset time, etc) ",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "Ldpn4e6hMsq8Xp-PeDVav",
      "type": "text",
      "x": 314.01171875,
      "y": 414.8671875,
      "width": 466.9794616699219,
      "height": 108,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a2",
      "roundness": null,
      "seed": 2130518498,
      "version": 502,
      "versionNonce": 1719752482,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776600714226,
      "link": null,
      "locked": false,
      "text": "Non-Functional Requirement\n- Minimal latency overhead (<10ms per req check)\n- Availability >> Consistency\n- Should handle 1Million req/sec across 100M DAU.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-Functional Requirement\n- Minimal latency overhead (<10ms per req check)\n- Availability >> Consistency\n- Should handle 1Million req/sec across 100M DAU.",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "WsY6EW0qdBuBDiXVq83JD",
      "type": "text",
      "x": 323.91015625,
      "y": 600.37890625,
      "width": 192.11976623535156,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
